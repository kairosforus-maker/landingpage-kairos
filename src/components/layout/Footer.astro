---
import { getLangFromUrl } from '../../i18n/data';

const lang = getLangFromUrl(Astro.url);
---

<footer class="footer">
  <div class="footer-container">
    <a href={lang === 'es' ? '/' : '/en'} class="footer-brand">Kαiros</a>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-dark);
    padding: 1.5rem 3rem;
    border-top: 1px solid #1a1a1a;
  }

  .footer-container {
    max-width: 1300px;
    margin: 0 auto;
    display: flex;
    align-items: center;
  }

  .footer-brand {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-primary);
  }
</style>
